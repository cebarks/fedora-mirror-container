# Required: upstream rsync mirror URL (must expose the fedora-buffet module)
# Find a mirror: https://mirrormanager.fedoraproject.org/
# Verify it has fedora-buffet: rsync <mirror-url>/
RSYNC_REMOTE=rsync://mirror.example.org

# Seconds between sync runs (default: 21600 = 6 hours)
# SYNC_INTERVAL=21600

# Host path for mirror data (default: /srv/fedora-mirror)
# MIRROR_DIR=/srv/fedora-mirror

# Host port for HTTP access (default: 8080)
# MIRROR_PORT=8080
